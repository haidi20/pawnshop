    "host": "localhost:8001",
    "basePath": "/api/v1",
    "paths": {
        "/products": {
            "get": {
                "description": "Mengembalikan daftar produk yang tersedia di warehouse (opsional filter `warehouse_id`)",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "Get products by warehouse",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Warehouse ID",
                        "name": "warehouse_id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/controller.GetProductsByWarehouseResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/controller.GetProductsByWarehouseErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Jika `:id` diberikan maka lakukan update, jika tidak maka buat baru.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "Simpan produk (create or update)",
                "parameters": [
                    {
                        "description": "Product payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Product"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/controller.ProductResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/controller.GetProductsByWarehouseErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/controller.GetProductsByWarehouseErrorResponse"
                        }
                    }
                }
            }
        },
        "/products/{id}": {
            "post": {
                "description": "Jika `:id` diberikan maka lakukan update, jika tidak maka buat baru.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "Simpan produk (create or update)",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Product ID",
                        "name": "id",
                        "in": "path"
                    },
                    {
                        "description": "Product payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Product"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/controller.ProductResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/controller.GetProductsByWarehouseErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/controller.GetProductsByWarehouseErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "description": "Menghapus produk (soft delete) berdasarkan ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "Hapus produk",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Product ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/controller.GetProductsByWarehouseErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/controller.GetProductsByWarehouseErrorResponse"
                        }
                    }
                }
            }
        },
        "/transactions": {
            "get": {
                "description": "Mendapatkan daftar transaksi dengan status pending berdasarkan warehouse ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Transaction"
                ],
                "summary": "Get transactions",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Warehouse ID",
                        "name": "warehouse_id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Transaction status filter (e.g. pending)",
                        "name": "status",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "data: array of transactions",
                        "schema": {
                            "$ref": "#/definitions/controller.GetPendingTransactionsResponse"
                        }
                    },
                    "400": {
                        "description": "error: warehouse_id invalid (transactions=[])",
                        "schema": {
                            "$ref": "#/definitions/controller.GetPendingTransactionsErrorResponse"
                        }
                    },
                    "500": {
                        "description": "error: internal server error (transactions=[])",
                        "schema": {
                            "$ref": "#/definitions/controller.GetPendingTransactionsErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Membuat transaksi baru dan memicu update WebSocket",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Transaction"
                ],
                "summary": "Buat data baru transaksi",
                "parameters": [
                    {
                        "description": "Data transaksi",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.StoreTransactionRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "message: success, data: full object",
                        "schema": {
                            "$ref": "#/definitions/controller.StoreTransactionResponse"
                        }
                    },
                    "400": {
                        "description": "error: bad request (transaction={}, details=[])",
                        "schema": {
                            "$ref": "#/definitions/controller.StoreTransactionErrorResponse"
                        }
                    },
                    "500": {
                        "description": "error: internal server error (transaction={}, details=[])",
                        "schema": {
                            "$ref": "#/definitions/controller.StoreTransactionErrorResponse"
                        }
                    }
                }
            }
        },
        "/warehouses": {
            "get": {
                "description": "Mendapatkan daftar warehouse yang `is_active = true` dan memiliki setidaknya satu shift",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Warehouse"
                ],
                "summary": "Get active warehouses that have shifts",
