# Example environment file for docker-compose (copy to .env and fill values)
# Do NOT commit your real .env file with secrets.

APP_PORT=8080
APP_ENV=development

# MySQL settings for docker-compose
MYSQL_ROOT_PASSWORD=CHANGEME_ROOT_PASSWORD
MYSQL_DATABASE=myapp
MYSQL_USER=appuser
MYSQL_PASSWORD=CHANGEME_DB_PASSWORD

# Database settings used by the application (point to the MySQL container)
DB_HOST=db
DB_PORT=3306
DB_USER=appuser
DB_PASS=CHANGEME_DB_PASSWORD
DB_NAME=myapp
