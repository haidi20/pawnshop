{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode dev-local",
    "dev:local-public": "vite --host --mode dev-local-public",
    "dev:dev": "vite --mode dev",
    "dev:prod": "vite --mode prod",
    "build:local": "vue-tsc --noEmit && vite build --mode dev-local",
    "build:dev": "vue-tsc --noEmit && vite build --mode dev",
    "build:prod": "vue-tsc --noEmit && vite build --mode prod",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,vue --ignore-path .gitignore --fix",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write src/",
    "analyze": "npm run type-check && npm run lint",
    "writer:start": "node scripts/file_manager.js"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@vueuse/rxjs": "^14.0.0",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "fp-ts": "^2.16.11",
    "lodash-es": "^4.17.21",
    "pinia": "^2.2.0",
    "rxdb": "^16.21.1",
    "rxjs": "^7.8.2",
    "socket.io-client": "2.3.0",
    "sweetalert2": "^11.26.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.22",
    "vue-router": "^4.4.2"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@types/socket.io": "^2.1.13",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.5.1",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.2.0",
    "prettier": "^3.6.2",
    "sass": "^1.94.0",
    "sass-loader": "^16.0.6",
    "socket.io": "2.4.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.5.3",
    "vite": "^7.1.11",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vitest": "^4.0.13",
    "vue-tsc": "^2.1.2"
  }
}
